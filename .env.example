# =====================================================
# 3Vírgulas Chat - Environment Variables
# =====================================================
# Copie este arquivo para .env.local e preencha os valores
# =====================================================

# Supabase Configuration
# Encontre em: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Venice AI API
# Obtenha em: https://venice.ai/settings/api
VITE_VENICE_API_KEY=your_venice_api_key_here

# App Configuration (opcional)
VITE_APP_NAME=3Vírgulas
VITE_APP_URL=http://localhost:5173
